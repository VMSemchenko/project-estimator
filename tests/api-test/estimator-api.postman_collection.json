    {
      "name": "Create Estimation",
      "item": [
        {
          "name": "E-Commerce Platform (React/NestJS)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 202', function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "pm.test('Response has job ID', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.collectionVariables.set('job_id', jsonData.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inputFolder\": \"apps/api/assets/samples/sample-project\",\n  \"outputFolder\": \"output/sample-project\",\n  \"verbose\": true\n}"
            },
            "url": {
              "raw": "{{API_BASE_URL}}/estimate",
              "host": ["{{API_BASE_URL}}"],
