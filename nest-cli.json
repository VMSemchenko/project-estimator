{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.json",
    "assets": ["**/*.md", "**/*.yaml", "**/*.yml"],
    "watchAssets": true
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.json",
        "assets": ["**/*.md", "**/*.yaml", "**/*.yml"],
        "watchAssets": true
      }
    }
  }
}
