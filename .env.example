# ==============================================================================
# BA Work Estimation System - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------------------------
# ZhipuAI Configuration (Required)
# ------------------------------------------------------------------------------
# Get your API key from: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
ZHIPUAI_BASE_URL=https://api.z.ai/api/paas/v4

# LLM model for agent reasoning
LLM_MODEL=glm-5

# Embedding model for vector search
EMBEDDING_MODEL=embedding-2

# ------------------------------------------------------------------------------
# MongoDB Atlas Configuration (Required)
# ------------------------------------------------------------------------------
# MongoDB Atlas connection string with Vector Search enabled
# Format: mongodb+srv://<username>:<password>@cluster0.mongodb.net/estimator?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/estimator?retryWrites=true&w=majority

# Vector search index name (must match your Atlas Vector Search index)
VECTOR_SEARCH_INDEX=vector_index

# ------------------------------------------------------------------------------
# Langfuse Configuration (Optional - for observability)
# ------------------------------------------------------------------------------
# Enable Langfuse tracing for LLM observability
LANGFUSE_ENABLED=false

# Get your keys from: https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here

# Langfuse host (use self-hosted URL if applicable)
LANGFUSE_HOST=https://cloud.langfuse.com

# ------------------------------------------------------------------------------
# OpenAI Configuration (Optional - alternative embedding provider)
# ------------------------------------------------------------------------------
# Only needed if using OpenAI for embeddings instead of ZhipuAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ------------------------------------------------------------------------------
# Local Embedding Configuration (Optional - for offline embeddings)
# ------------------------------------------------------------------------------
# Use local transformers.js model for embeddings (no API calls)
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# ------------------------------------------------------------------------------
# Catalog Configuration
# ------------------------------------------------------------------------------
# Default catalog set to use: "demo" or "real-world"
CATALOG_SET=demo
