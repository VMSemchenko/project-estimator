# ===========================================
# BA Work Estimation System - Environment Variables
# ===========================================

# Application
NODE_ENV=development
PORT=3000

# ZhipuAI (GLM) - LLM Provider
# Get your API key from: https://open.bigmodel.cn/
ZHIPUAI_API_KEY=your_zhipuai_api_key
LLM_MODEL=glm-5
EMBEDDING_MODEL=embedding-3

# ZhipuAI Base URL (OpenAI-compatible)
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# MongoDB Atlas
# Replace <username>, <password>, and <cluster> with your Atlas credentials
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/estimator?retryWrites=true&w=majority

# MongoDB Atlas Vector Search Index Name
VECTOR_SEARCH_INDEX=vector_index

# Langfuse - LLM Observability & Tracing
# Get your keys from: https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: Enable/disable Langfuse tracing
LANGFUSE_ENABLED=true

# Logging
LOG_LEVEL=debug
