{
  "name": "ba-work-estimator",
  "version": "0.1.0",
  "description": "BA Work Estimation System - Multi-agent RAG system for business analyst work estimation",
  "private": true,
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api/test/jest-e2e.json",
    "cli": "ts-node apps/api/src/cli/index.ts",
    "estimate": "ts-node apps/api/src/cli/index.ts estimate",
    "catalog:index": "ts-node apps/api/src/cli/index.ts catalog index",
    "catalog:status": "ts-node apps/api/src/cli/index.ts catalog status"
  },
  "dependencies": {
    "@langchain/community": "^0.3.35",
    "@langchain/core": "^0.3.42",
    "@langchain/google-genai": "^0.1.8",
    "@langchain/langgraph": "^0.2.55",
    "@langchain/mongodb": "^0.1.0",
    "@langchain/openai": "^0.3.17",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "langfuse": "^3.29.1",
    "langfuse-langchain": "^3.29.1",
    "mongodb": "^6.12.0",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.12",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/api/src/"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/apps/api/src/$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(langfuse|langfuse-langchain|langfuse-core)/)"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
